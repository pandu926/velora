# ─── Agent wallet (server-side, NEVER commit real values) ───────────────────
# Commander agent: signs delegations and submits via 1Shot relayer
PRIVATE_KEY=0x...

# OPTIONAL — Trader specialist's own key, for a fully independent A2A party.
# If omitted, the Trader shares the Commander address (demo still works, but a
# separate key makes the agent-to-agent relationship provably two distinct parties).
TRADER_PRIVATE_KEY=0x...

# ─── Chain (Base MAINNET — required by the 1Shot track) ─────────────────────
RPC_URL=https://mainnet.base.org
CHAIN_ID=8453

# ─── 1Shot Permissionless Relayer (no signup / no key needed) ───────────────
ONESHOT_RELAYER_URL=https://relayer.1shotapi.com/relayers
ONESHOT_API_KEY=

# Public base URL the relayer POSTs status webhooks to (scores higher).
# e.g. https://velora.rbexp.com  → webhook lands at /api/webhook/relayer
WEBHOOK_BASE_URL=

# ─── Server port ────────────────────────────────────────────────────────────
PORT=8930

# ─── Venice AI (wallet-native x402 auth — no API key needed) ────────────────
# This wallet pays for inference via x402 on Base mainnet (USDC).
VENICE_PRIVATE_KEY=0x...
VENICE_API_URL=https://api.venice.ai/api/v1
VENICE_MODEL=zai-org-glm-5-1
# OPTIONAL — use a Venice Bearer key instead of wallet SIWE auth:
VENICE_API_KEY=

# ─── Hermes AI (research/debate — Scout & Skeptic agents) ───────────────────
# OpenAI-compatible endpoint. Venice, Pioneer, or any provider with chat completions.
HERMES_API_KEY=sk-...
HERMES_BASE_URL=https://api.venice.ai/api/v1
HERMES_MODEL=deepseek-ai/DeepSeek-V4-Flash
